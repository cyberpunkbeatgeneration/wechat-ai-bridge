# WeChat AI Bridge - Environment Variables
# Copy this file to .env and fill in your API keys

# ============ DeepSeek (via Doubao Ark) ============
DOUBAO_API_KEY=
DEEPSEEK_BOT_ID=

# ============ Qwen (Alibaba) ============
QWEN_API_KEY=sk-

# ============ Gemini (Google) ============
GOOGLE_API_KEY=AIza

# ============ Doubao ============
DOUBAO_BOT_ID=

# ============ Kimi (Moonshot) ============
MOONSHOT_API_KEY=sk-

# ============ MiniMax ============
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ============ GPT (OpenAI) ============
OPENAI_API_KEY=sk-

# ============ Claude API (Optional, as sub-model) ============
ANTHROPIC_API_KEY=sk-ant-

# ============ WeChat Bot Token (Optional) ============
# If set, will use this instead of local credentials
# BOT_TOKEN=
